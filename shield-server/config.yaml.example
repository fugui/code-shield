# ============================================================
# Code Shield 服务端配置模版文件 (config.yaml.example)
# 使用方法：复制本文件为 config.yaml，并根据实际情况修改配置值
# ============================================================

# ── HTTP 服务 ──
server:
  port: ":8080"                  # 服务监听端口
  # external_url: "http://127.0.0.1:8080"  # 外部访问基准 URL（邮件等通知链接跳转，缺省默认为本地端口地址）
  # worker_count: 5              # 全局任务并发数，默认 5
  # gin_log: true                # 是否打印 GIN 框架请求日志，默认 false
  # read_timeout: 15s            # 读取 HTTP 请求超时时间，默认 15s
  # write_timeout: 15s           # 写入响应超时时间，默认 15s
  # idle_timeout: 60s            # keep-alive 空闲连接超时时间，默认 60s

# ── 数据存储 ──
storage:
  root: "/home/fugui/test_root"  # 数据根目录，下设 codes/ 和 reports/ 子目录（建议配置为绝对路径）

# ── AI 引擎 ──
ai:
  backend: "claude"              # AI 驱动 CLI 后端：可选 claude 或 opencode，默认 claude
  # debug_logs: true             # 是否输出 AI 引擎底层的 debug 级别日志，默认 false。开启后会在报告同级目录下生成 .debug.log 文件方便定位
  # output_format: "text"        # AI 输出的格式：text 或 json（对 claude 来说是 text/stream-json，对 opencode 来说是 default/json），默认 text

  # ── 多 LLM 服务器并发配置 (可选) ──
  # 启用多 LLM 服务器配置时，全局任务并发数限制会被本配置的并发总和自动拓展，
  # 每次 AI 扫描时根据后端类型自动映射对应的模型名称，精准控制每台服务器的并发负载。
  # models:
  #   - opencode: "models/glm5.1"
  #     claude: "glm5.1"
  #     concurrent: 5
  #   - opencode: "models/qwen3.5"
  #     concurrent: 2

# ── 通知服务 ──
notification:
  webhook: "http://127.0.0.1:8081/api/notify/email"  # 分析完毕后发送报告卡片通知的回调地址

# ── 认证 ──
auth:
  jwt_secret: ""                     # JWT 签名密钥（至少 32 字符，留空则启动时随机生成临时密钥，重启后所有会话失效）
  password_login_enabled: false      # 是否启用传统用户名/密码登录（若 OAuth2 未启用则自动启用作为兜底）
  # portal_jwt_secret: ""            # 兼容旧版 Portal SSO 的共享 JWT 密钥（留空禁用）

  oauth2:
    enabled: false                   # 是否启用 OAuth2 / OIDC 单点登录
    client_id: "code-shield"         # 在 OAuth2 Provider 中注册的 Client ID
    client_secret: ""                # Client Secret（建议通过环境变量注入或使用密钥管理服务）
    auth_url: "https://sso.yourcompany.com/realms/main/protocol/openid-connect/auth"      # Authorization Endpoint
    token_url: "https://sso.yourcompany.com/realms/main/protocol/openid-connect/token"     # Token Endpoint
    userinfo_url: "https://sso.yourcompany.com/realms/main/protocol/openid-connect/userinfo" # UserInfo Endpoint
    redirect_url: ""                 # 回调地址（留空则自动根据 external_url 推导为 <external_url>/api/oauth2/callback）
    scopes: ["openid", "profile", "email"]  # 请求的 OAuth2 Scopes
    # admin_list: ["fugui", "admin@company.com"]  # SSO 登录自动提权为系统管理员的邮箱/用户名白名单列表
    field_mapping:                   # IdP 返回的用户属性字段映射
      username: "preferred_username" # 映射为系统用户名的字段
      email: "email"                 # 映射为邮箱的字段
      name: "name"                   # 映射为显示名称的字段
      employee_id: "employee_id"     # 映射为工号的字段
      unique_id: "unique_id"         # 映射为身份证等唯一ID的字段
      employee_type: "employee_type" # 映射为员工类型的字段
    dept_api_url: ""                 # SSO 登录后如果部门信息缺失，由前端浏览器请求以同步用户部门名称的外部 API 地址

