#!/bin/bash

# 搜索C/C++代码中的线程创建情况
# 输入: $1 = 代码仓本地路径
# 退出码: 0=继续, 1=跳过, 2=失败
# 标准输出: 跳过/失败原因

CODES_PATH="$1"

if [ -z "$CODES_PATH" ]; then
    echo "未提供代码路径参数"
    exit 2
fi

if [ ! -d "$CODES_PATH/.git" ]; then
    echo "指定路径不是 git 仓库"
    exit 2
fi

# 切换到目标目录
if ! cd "$CODES_PATH" 2>/dev/null; then
    echo "无法切换到目录: $CODES_PATH"
    exit 2
fi

# 定义要搜索的线程创建关键词
thread_keywords=(
    "pthread_create"
    "std::thread"
    "CFThreadCreate"
    "QThread"
    "omp parallel"
    "boost::asio::io_context"
    "boost::asio::thread_pool"
)

# 构建grep模式，使用-E进行扩展正则匹配
pattern=$(IFS='|'; echo "${thread_keywords[*]}")

# 搜索C/C++源文件
# 使用find -exec + 提高效率
result=$(find . -type f \( -name "*.c" -o -name "*.cpp" -o -name "*.cc" -o -name "*.cxx" -o -name "*.h" -o -name "*.hpp" -o -name "*.hxx" \) -exec grep -lE "$pattern" {} + 2>/dev/null | head -1)

if [ -n "$result" ]; then
    echo "Thread creation detected in codebase."
    echo "Found in: $result"
    exit 0
else
    echo "代码中没有显式的线程创建语句（如 pthread_create、std::thread 等 ）"
    exit 1
fi