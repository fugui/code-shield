{
  "name": "memory_leak",
  "display_name": "内存泄漏检测",
  "description": "专项检测代码中的内存泄漏风险，包括未关闭资源、循环引用等",
  "engine_mode": "chunked",
  "engine_config": {
    "file_extensions": [
      ".c",
      ".cpp",
      ".cc",
      ".cxx",
      ".h",
      ".hpp",
      ".hxx"
    ],
    "exclude_paths": [
      "thirdparts"
    ]
  },
  "ai_backend": "",
  "target_scope": "business",
  "notify_template": "【Code-Shield】{{.RepoName}} {{.TaskDisplayName}}报告",
  "notify_threshold": 10,
  "notify_cc": [],
  "timeout": 60,
  "is_active": true
}