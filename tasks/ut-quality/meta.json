{
  "name": "ut_quality",
  "display_name": "单元测试代码质量审计",
  "description": "针对单元测试的代码质量进行审计，识别代码坏味道、脆弱测试、资源泄漏、过度 Mock 及硬编码等工程质量问题",
  "engine_mode": "chunked",
  "engine_config": {
    "file_extensions": [
      ".c",
      ".cpp",
      ".cc",
      ".cxx",
      ".h",
      ".hpp",
      ".hxx",
      ".py",
      ".java",
      ".go"
    ],
    "exclude_paths": [
      "thirdparts"
    ]
  },
  "ai_backend": "",
  "target_scope": "test",
  "notify_template": "【Code-Shield】{{.RepoName}} {{.TaskDisplayName}}报告",
  "notify_threshold": 10,
  "notify_cc": [],
  "timeout": 60,
  "is_active": true
}